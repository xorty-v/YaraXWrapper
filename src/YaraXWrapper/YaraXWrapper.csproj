<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>netstandard2.0</TargetFramework>
        <LangVersion>12.0</LangVersion>
        <Nullable>enable</Nullable>
        <ImplicitUsings>disable</ImplicitUsings>
        <PackageId>YaraXWrapper</PackageId>
        <Title>YaraXWrapper</Title>
        <Version>0.1.0</Version>
        <Authors>x1m</Authors>
        <Description>.NET Standard 2.0 wrapper for the YARA-X C API. Bundles yara_x_capi.dll $(YaraXCapiVersion) (win-x64 only).</Description>
        <PackageProjectUrl>https://github.com/xorty-v/YaraXWrapper</PackageProjectUrl>
        <PackageTags>yara;yara-x;capi;interop;wrapper;dotnet;netstandard</PackageTags>
        <PackageLicenseExpression>MIT</PackageLicenseExpression>
        <RepositoryUrl>https://github.com/xorty-v/YaraXWrapper</RepositoryUrl>
        <RepositoryType>git</RepositoryType>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="System.Text.Json" Version="8.0.5"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="..\..\README.md" Pack="true" PackagePath="\"/>
        <None Include="..\..\LICENSE" Pack="true" PackagePath="\"/>
    </ItemGroup>

    <ItemGroup>
        <None Include="yara_x_capi\$(YaraXCapiVersion)\yara_x_capi.dll"
              Pack="true"
              PackagePath="runtimes\win-x64\native\"
              CopyToOutputDirectory="PreserveNewest"
              TargetPath="%(Filename)%(Extension)"/>
    </ItemGroup>

</Project>